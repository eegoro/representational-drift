    "# ============================================================\n",
    "# DAY 1 — Memory Encoding  (shared across all conditions)\n",
    "# ============================================================\n",
    "\n",
    "# Use fixed seed for Day 1 (deterministic encoding)\n",
    "\n",
    "# --- OU Process Function ---\n",
    "def ornstein_uhlenbeck(T, tau, sigma, dt, seed):\n",
    "    \"\"\"Generate OU process: dε = -ε dt/τ + σ √(2dt/τ) ξ(t)\"\"\"\n",
    "    rng = np.random.RandomState(seed)\n",
    "    eps = np.zeros((T, N))\n",
    "    for t in range(1, T):\n",
    "        eps[t] = eps[t-1] - (eps[t-1] / tau) * dt + sigma * np.sqrt(2 * dt / tau) * rng.randn(N)\n",
    "    return torch.tensor(eps, dtype=torch.float32)\n",
    "\n",
    "# --- Generate the OU Ambient Noise ---\n",
    "# We use the parameters from your initial setup\n",
    "I_ambient_ou = ornstein_uhlenbeck(T_DAY1, TAU_EPS, SIGMA_EPS, dt, seed=42)\n",
    "# Center it so it provides a positive excitatory baseline roughly around 0.2\n",
    "I_ambient_ou += 0.4\n",
    "\n",
    "# --- Memory Pattern ---\n",
    "I_mem = torch.zeros(N)\n",
    "indices_active = [0, 3, 4, 5, 7]\n",
    "amplitudes     = [0.6, 0.85, 0.2, 1.1, 0.95]\n",
    "for i, amp in zip(indices_active, amplitudes):\n",
    "    I_mem[i] = amp\n",
    "\n",
    "I_p = -3.0 * torch.ones(N)\n",
    "\n",
    "# --- Simulation Phase lengths ---\n",
    "T_PHASE_0 = 1000  # Doubled State 0 (10s) to allow for \"burn-in\" restabilization\n",
    "T_PHASE_1 = 500  # Encoding\n",
    "T_PHASE_2 = 1000   # Consolidation\n",
    "T_TOTAL_NEW = T_PHASE_0 + T_PHASE_1 + T_PHASE_2\n",
    "\n",
    "# Regenerate OU noise for the longer duration\n",
    "I_ambient_ou = ornstein_uhlenbeck(T_TOTAL_NEW, TAU_EPS, SIGMA_EPS, dt, seed=42)\n",
    "I_ambient_ou += 0.3 # Slightly higher offset to jumpstart initial activity\n",
    "\n",
    "net = HebbianNetwork(**PARAMS)\n",
    "r_d1_hist = []\n",
    "W_snaps = {}\n",
    "print(\"Running Restabilization Phase...\")\n",
    "\n",
    "for t in tqdm(range(T_TOTAL_NEW)):\n",
    "    ambient_t = I_ambient_ou[t]\n",
    "    \n",
    "    if t < T_PHASE_0:\n",
    "        # STATE 0: Restabilizing baseline. \n",
    "        # Homeostasis will pull the MFR up to the red line here.\n",
    "        current_input = ambient_t\n",
    "    elif T_PHASE_0 <= t < (T_PHASE_0 + T_PHASE_1):\n",
    "        # STATE 1: Memory Injection\n",
    "        current_input = ambient_t + I_mem\n",
    "    else:\n",
    "        # STATE 2: Consolidation\n",
    "        current_input = ambient_t\n",
    "\n",
    "    # Step with homeostasis ALWAYS ON\n",
    "    net.step(current_input, noise_std=0.00, homeostasis=False)\n",
    "    \n",
    "    if t == T_PHASE_0 - 1:\n",
    "        W_snaps['State 0'] = net.W.cpu().numpy().copy()\n",
    "    if t == (T_PHASE_0 + T_PHASE_1) - 1:\n",
    "        W_snaps['Memory Encoded'] = net.W.cpu().numpy().copy()\n",
    "    if t == T_TOTAL_NEW - 1:\n",
    "        W_snaps['Consolidated'] = net.W.cpu().numpy().copy()\n",
    "\n",
    "    if t % REC_EVERY == 0:\n",
    "        r_d1_hist.append(net.r.cpu().numpy().copy())\n",
    "\n",
    "# For graphing MFR with the injection point clearly marked\n",
    "\n",
    "t_injection_step = T_PHASE_0\n",
    "t_injection_seconds = t_injection_step * dt / 1000.0\n",
    "\n",
    "r_d1_hist = np.array(r_d1_hist)\n"
   ]
