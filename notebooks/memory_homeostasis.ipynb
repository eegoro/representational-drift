    "        ax.plot(t_d1, res['m_mem_d1'], color='gray', lw=1.5, label='Day 1 (shared)')\n",
    "    ax.plot(off2 + t_d2, res['m_mem_d2'], color=c, ls=ls, lw=1.5)\n",
    "    ax.plot(off3 + t_d3, res['m_mem_d3'], color=c, ls=ls, lw=1.5, label=cond_name)\n",
