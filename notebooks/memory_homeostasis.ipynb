    "t_d2  = np.arange(len(base['r_d2'])) * REC_EVERY * dt / 1000.0\n",
    "t_d3  = np.arange(len(base['r_d3'])) * REC_EVERY * dt / 1000.0\n",
    "gap   = REC_EVERY * dt / 1000.0\n",
