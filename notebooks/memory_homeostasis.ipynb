    "# ============================================================\n",
    "# Export Day 1 state for Day 2/3 experiments\n",
    "# ============================================================\n",
    "\n",
    "# --- 1. Final weights and state ---\n",
    "W_d1 = net.W.clone().detach()\n",
    "r_d1_final = net.r.clone().detach()\n",
    "\n",
    "# --- 2. Extract the ACTUAL stored memory pattern ---\n",
    "# Convert history to numpy if not already\n",
    "r_d1_hist_np = np.array(r_d1_hist)\n",
    "\n",
    "# Indices corresponding to encoding phase\n",
    "enc_start = T_PHASE_0 // REC_EVERY\n",
    "enc_end   = (T_PHASE_0 + T_PHASE_1) // REC_EVERY\n",
    "\n",
    "# Average activity during encoding\n",
    "r_m_np = r_d1_hist_np[enc_start:enc_end].mean(axis=0)\n",
    "\n",
    "# Convert back to torch\n",
    "r_m = torch.tensor(r_m_np, dtype=torch.float32)\n",
    "\n",
    "# --- 3. Normalize for stable similarity readout ---\n",
    "r_m_norm = np.linalg.norm(r_m_np) + 1e-8\n",
    "\n",
    "# --- 4. Structural reference weights (post-consolidation) ---\n",
    "W_struct_np = net.W.cpu().numpy().copy()\n",
    "\n",
    "# --- 5. Sanity checks ---\n",
    "cos_final = torch.dot(r_d1_final, r_m) / (\n",
    "    torch.norm(r_d1_final) * torch.norm(r_m) + 1e-8\n",
    ")\n",
    "\n",
    "print(\"Day 1 export complete:\")\n",
    "print(f\"Final mean firing rate: {r_d1_final.mean().item():.3f}\")\n",
    "print(f\"Memory alignment (final vs encoded): {cos_final.item():.3f}\")\n",
    "print(f\"Memory sparsity (#active > mean): {(r_m_np > r_m_np.mean()).sum()}/{N}\")"
   ]
