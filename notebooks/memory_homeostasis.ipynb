    "ax.set_ylabel(r'$m_{\\mathrm{mem}}$')\n",
    "ax.set_title('(a) Memory readout across three days')\n",
    "ax.legend(fontsize=8, loc='lower right', ncol=2)\n",
    "\n",
    "ax2 = axes[1]\n",
